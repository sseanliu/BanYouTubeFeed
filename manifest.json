{
  "manifest_version": 3,
  "name": "Ban Feed",
  "version": "1.1.0",
  "description": "Hide feeds on YouTube and LinkedIn. Stay focused.",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "css": [
        "linkedin.css"
      ],
      "run_at": "document_start"
    }
  ]
}
